    {
      "name": "GetBooking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Verify Status code is 200 - Booking Details Retrieved\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Verify Content-Type is present\", function () {",
              "    pm.response.to.have.header(\"Content-Type\");",
              "});",
              "",
              "pm.test(\"Verify Response time is less than 1500ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1500);",
              "});",
              "",
              "pm.test(\"Verify Firstname matches environment variable and is valid\", function () {",
              "    pm.expect(jsonData.firstname).to.be.a('string');",
              "    pm.expect(jsonData.firstname).to.not.be.empty;",
              "    pm.expect(jsonData.firstname).to.eql(pm.environment.get(\"fname\"));",
              "});",
              "",
              "pm.test(\"Verify Lastname matches environment variable and is valid\", function () {",
              "    pm.expect(jsonData.lastname).to.be.a('string');",
              "    pm.expect(jsonData.lastname).to.not.be.empty;",
              "    pm.expect(jsonData.lastname).to.eql(pm.environment.get(\"lname\"));",
              "});",
              "",
              "pm.test(\"Verify Total price and Deposit status are valid\", function () {",
              "    pm.expect(jsonData.totalprice).to.be.a('number');",
              "    pm.expect(jsonData.totalprice).to.be.at.least(0);",
              "    pm.expect(jsonData.depositpaid).to.be.a('boolean');",
              "});",
              "",
              "",
              "pm.test(\"Verify Booking Dates structure\", function () {",
              "    pm.expect(jsonData.bookingdates).to.have.property('checkin');",
              "    pm.expect(jsonData.bookingdates).to.have.property('checkout');",
              "});",
              "",
              "pm.test(\"Verify Booking Dates are in correct format (YYYY-MM-DD)\", function () {",
              "    pm.expect(jsonData.bookingdates.checkin).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
              "    pm.expect(jsonData.bookingdates.checkout).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
