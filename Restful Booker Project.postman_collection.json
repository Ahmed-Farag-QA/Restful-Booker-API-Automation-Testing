    {
      "name": "CreateBooking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// تعريف الـ Response مرة واحدة في أول السكريبت ونستخدمه في كل مكان\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Verify Status code is 200 - Booking Created\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Content-Type is present\", function () {\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Response time is less than 1500ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1500);\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Booking ID is generated as a valid number\", function () {\r",
              "    pm.expect(jsonData.bookingid).to.be.a('number');\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Firstname is valid\", function () {\r",
              "    pm.expect(jsonData.booking.firstname).to.be.a('string');\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Lastname is valid\", function () {\r",
              "     pm.expect(jsonData.booking.lastname).to.be.a('string');\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Firstname is not empty\", function () {\r",
              "    pm.expect(jsonData.booking.firstname).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Lastname is not empty\", function (){\r",
              "    pm.expect(jsonData.booking.lastname).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Total price is a valid amount\", function () {\r",
              "    pm.expect(jsonData.booking.totalprice).to.be.at.least(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Booking Dates are in correct format\", function () {\r",
              "    pm.expect(jsonData.booking.bookingdates.checkin).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Total Price and Deposit status\", function () {\r",
              "    pm.expect(jsonData.booking.totalprice).to.be.a('number');\r",
              "    pm.expect(jsonData.booking.depositpaid).to.be.a('boolean');\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Booking Dates structure\", function () {\r",
              "    pm.expect(jsonData.booking.bookingdates).to.have.property('checkin');\r",
              "    pm.expect(jsonData.booking.bookingdates).to.have.property('checkout');\r",
              "});\r",
              "\r",
              "pm.test(\"Verify Booking Dates are in correct format\", function () {\r",
              "    pm.expect(jsonData.booking.bookingdates.checkin).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);\r",
              "});\r",
              "\r",
              "// حفظ المتغيرات في البيئة بشكل صحيح باستخدام jsonData\r",
              "pm.environment.set(\"BookID\", jsonData.bookingid);\r",
              "pm.environment.set(\"fname\", jsonData.booking.firstname); // تأكد إن الاسم fname زي الـ Requests الباقية\r",
              "pm.environment.set(\"lname\", jsonData.booking.lastname);  // تأكد إن الاسم lname زي الـ Requests الباقية"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
